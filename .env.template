# Required (if not using mounted ~/.claude.json credentials). Anthropic API key for Claude Code.
ANTHROPIC_API_KEY=

# Optional. Enables text-to-speech, audio transcription, and progress summarization.
OPENAI_API_KEY=

# Optional. LangSmith API key. Enables tracing and observability via LangSmith.
LANGSMITH_API_KEY=

# Optional. LangSmith project name for organizing traces.
LANGSMITH_PROJECT=

# Optional. Set to "true" to enable LangSmith tracing.
LANGSMITH_TRACING=true
