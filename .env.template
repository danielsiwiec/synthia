# Required. PostgreSQL connection string for pgvector. Used for memory and document storage.
POSTGRES_CONNECTION_STRING=postgresql://postgres:postgres@pgvector:5432/vector_store

# Optional. Username for the memory system. Identifies whose memories to store and retrieve. Defaults to "default".
MEMORY_USER=

# Optional. Enables Discord integration. Both DISCORD_BOT_TOKEN and DISCORD_CHANNEL must be set.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL=

# Optional. Enables text-to-speech, audio transcription, progress summarization, and schema parsing.
OPENAI_API_KEY=

# Optional. Google Gemini API key. Enables image generation capabilities.
GEMINI_API_KEY=

# Optional. LangSmith API key. Enables tracing and observability via LangSmith.
LANGSMITH_API_KEY=

# Optional. LangSmith project name for organizing traces.
LANGSMITH_PROJECT=

# Optional. Set to "true" to enable LangSmith tracing.
LANGSMITH_TRACING=true
